{
  "expo": {
    "name": "rugby-fantasy-mobile",
    "slug": "rugby-fantasy-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/crbvjpg.jpg", 
    "scheme": "rugbyfantasymobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#283a82",
        "foregroundImage": "./assets/images/crbvjpg.jpg"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/crbvjpg.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/crbvjpg.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#283a82"
        }
      ]
    ]
  }
}